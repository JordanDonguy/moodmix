# Default — HTML (root + every SPA route) must never be cached so clients
# always pick up the latest asset hashes on their next navigation. no-store
# also disables the bfcache, which max-age=0 + must-revalidate does not.
/*
  Cache-Control: no-store

# Hashed, immutable assets — cache forever (overrides /* above)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static files with stable paths — cache with revalidation
/fonts/*
  Cache-Control: public, max-age=2592000, must-revalidate

/favicon/*
  Cache-Control: public, max-age=2592000, must-revalidate
