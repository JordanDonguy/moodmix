# Database (local dev uses docker-compose.dev.yml, prod uses Supabase)
DATABASE_URL=postgresql+asyncpg://moodmix:moodmix@localhost:5433/moodmix

# YouTube Data API v3
YOUTUBE_API_KEY=<your_youtube_api_key>

# LLM API (for classifier + AI search)
LLM_API_KEY=<your_llm_api_key>
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Resend (contact form)
RESEND_API_KEY=<your_resend_api_key>
RESEND_API_URL=https://api.resend.com/emails
CONTACT_FROM_EMAIL=<your_contact_from_email>
CONTACT_TO_EMAIL=<your_contact_to_email>

# Admin API key (protects /api/admin/* endpoints)
ADMIN_API_KEY=<your_admin_api_key>

# JWT secret
JWT_SECRET=<your_jwt_secret>

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Environment
ENV=dev
