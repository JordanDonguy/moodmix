# Database (local dev uses docker-compose.dev.yml, prod uses Supabase)
DATABASE_URL=postgresql+asyncpg://moodmix:moodmix@localhost:5433/moodmix

# YouTube Data API v3
YOUTUBE_API_KEY=<your_youtube_api_key>

# LLM API (for classifier + AI search)
LLM_API_KEY=<your_llm_api_key>
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Resend (contact form)
RESEND_API_KEY=<your_resend_api_key>
RESEND_API_URL=https://api.resend.com/emails
CONTACT_FROM_EMAIL=<your_contact_from_email>
CONTACT_TO_EMAIL=<your_contact_to_email>

# Admin API key (protects /api/admin/* endpoints)
ADMIN_API_KEY=<your_admin_api_key>

# JWT secret
JWT_SECRET=<your_jwt_secret>

# Email sign-in codes
AUTH_FROM_EMAIL=<your_auth_from_email>
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_MAX_ATTEMPTS=5

# Auth cookies
ACCESS_COOKIE_NAME=<your_access_cookie_name>
REFRESH_COOKIE_NAME=<your_refresh_cookie_name>
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE="lax"

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Frontend app name and logo URL (for email links)
APP_NAME=<your_app_name>
APP_LOGO_URL=<your_app_logo_url>

# Environment
ENV=dev
